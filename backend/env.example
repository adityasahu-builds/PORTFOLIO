# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend Configuration (Your Vercel deployment URL)
FRONTEND_URL=https://your-portfolio-domain.vercel.app

# Database Configuration (Your MongoDB connection string, e.g. MongoDB Atlas)
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# Authentication Secrets
JWT_SECRET=your_jwt_access_secret_key_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="Your Name Portfolio" <your_email@gmail.com>
CONTACT_RECEIVER_EMAIL=your_email@gmail.com

# Cloudinary Configuration (Optional for media uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
